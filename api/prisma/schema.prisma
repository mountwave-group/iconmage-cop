// ICON IMAGE — CRM data model
// Prisma schema · Postgres 16

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-arm64-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ──────────────────────────────────────────────────────────────────

enum Role {
  OWNER
  PM_LEAD
  PM
  PERFORMER
  CLIENT
}

enum Tier {
  PRIVATE
  CORPORATE
  VIP
}

enum ClientStatus {
  LEAD
  ACTIVE
  DORMANT
  ARCHIVED
}

enum ServiceCategory {
  CONSULTING
  DIGITAL
  BRANDING
  CONTENT
  PR
  VIP
}

enum ProjectStatus {
  IN_MOTION
  AWAITING_APPROVAL
  ON_HOLD
  DELIVERED
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  BLOCKED
  COMPLETE
}

enum FinType {
  INCOME
  EXPENSE
}

enum FileVisibility {
  OWNER
  PM
  PERFORMER
  CLIENT
}

// ─── Core ───────────────────────────────────────────────────────────────────

model User {
  id               String   @id @default(uuid()) @db.Uuid
  email            String   @unique
  passwordHash     String
  fullName         String
  role             Role
  active           Boolean  @default(true)
  refreshTokenHash String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  assignedClients  Client[]         @relation("ClientAssignedPm")
  managedProjects  Project[]        @relation("ProjectPm")
  memberships      ProjectMember[]
  uploadedFiles    FileObject[]
  auditLogs        ActivityLog[]

  @@map("users")
}

model Client {
  id             String       @id @default(uuid()) @db.Uuid
  name           String
  country        String
  tier           Tier
  status         ClientStatus @default(ACTIVE)
  primaryContact String
  contactTitle   String?
  currency       String       @default("EUR") @db.Char(3)
  notes          String?      @db.Text
  assignedPmId   String?      @db.Uuid
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  assignedPm User?        @relation("ClientAssignedPm", fields: [assignedPmId], references: [id], onDelete: SetNull)
  projects   Project[]
  finRecords FinRecord[]
  files      FileObject[]

  @@index([status])
  @@index([assignedPmId])
  @@map("clients")
}

model Project {
  id              String          @id @default(uuid()) @db.Uuid
  clientId        String          @db.Uuid
  serviceCategory ServiceCategory
  serviceName     String
  status          ProjectStatus   @default(IN_MOTION)
  stageCurrent    Int             @default(1)
  stageTotal      Int             @default(1)
  dueAt           DateTime?
  budgetCents     BigInt?
  currency        String          @default("EUR") @db.Char(3)
  pmId            String?         @db.Uuid
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  client     Client          @relation(fields: [clientId], references: [id], onDelete: Restrict)
  pm         User?           @relation("ProjectPm", fields: [pmId], references: [id], onDelete: SetNull)
  members    ProjectMember[]
  tasks      ProjectTask[]
  finRecords FinRecord[]
  files      FileObject[]

  @@index([clientId])
  @@index([pmId])
  @@index([status])
  @@map("projects")
}

model ProjectMember {
  id             String   @id @default(uuid()) @db.Uuid
  projectId      String   @db.Uuid
  userId         String   @db.Uuid
  roleOnProject  Role
  createdAt      DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([userId])
  @@map("project_members")
}

model ProjectTask {
  id            String     @id @default(uuid()) @db.Uuid
  projectId     String     @db.Uuid
  title         String
  assigneeRole  Role
  status        TaskStatus @default(PENDING)
  dueAt         DateTime?
  kpi           String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([status])
  @@map("project_tasks")
}

model FinRecord {
  id         String   @id @default(uuid()) @db.Uuid
  clientId   String   @db.Uuid
  projectId  String?  @db.Uuid
  amountCents BigInt
  currency   String   @default("EUR") @db.Char(3)
  type       FinType
  region     String?
  createdBy  String?  @db.Uuid
  createdAt  DateTime @default(now())

  client  Client   @relation(fields: [clientId], references: [id], onDelete: Restrict)
  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([clientId])
  @@index([projectId])
  @@map("fin_records")
}

model FileObject {
  id           String         @id @default(uuid()) @db.Uuid
  bucket       String
  storageKey   String         @unique
  filename     String
  contentType  String
  sizeBytes    BigInt
  visibility   FileVisibility @default(OWNER)
  ownerUserId  String         @db.Uuid
  clientId     String?        @db.Uuid
  projectId    String?        @db.Uuid
  uploadedAt   DateTime?
  createdAt    DateTime       @default(now())

  owner   User     @relation(fields: [ownerUserId], references: [id], onDelete: Restrict)
  client  Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)
  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([ownerUserId])
  @@index([clientId])
  @@index([projectId])
  @@map("file_objects")
}

model ActivityLog {
  id           String   @id @default(uuid()) @db.Uuid
  actorUserId  String?  @db.Uuid
  action       String   @db.VarChar(64)
  entityType   String   @db.VarChar(64)
  entityId     String   @db.VarChar(64)
  diff         Json?
  ipAddress    String?  @db.VarChar(64)
  userAgent    String?  @db.VarChar(512)
  timestamp    DateTime @default(now())

  actor User? @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId])
  @@index([actorUserId])
  @@index([timestamp])
  @@map("activity_log")
}
