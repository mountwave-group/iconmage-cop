# --- Runtime ---
NODE_ENV=development
PORT=4000
CORS_ORIGIN=http://localhost:5173

# --- Database ---
DATABASE_URL=postgresql://iconimage:iconimage@localhost:5432/iconimage?schema=public

# --- Auth ---
JWT_ACCESS_SECRET=change-me-access-secret-at-least-32-chars-long
JWT_REFRESH_SECRET=change-me-refresh-secret-at-least-32-chars-long
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
BCRYPT_ROUNDS=12

# --- AWS S3 (or MinIO) ---
S3_REGION=eu-west-2
S3_BUCKET=iconimage-private
S3_ENDPOINT=
S3_FORCE_PATH_STYLE=false
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
STORAGE_MAX_BYTES=52428800
STORAGE_PRESIGN_TTL_SECONDS=300
